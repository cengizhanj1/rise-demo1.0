<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rise_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rise"
        android:textColor="#FFFFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetCompletedCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="0 / 0 habits completed"
        android:textColor="#FFE5E7EB"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/widgetCompletionPercent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0% completed"
        android:textColor="#FF9CA3AF"
        android:textSize="13sp" />
</LinearLayout>
